{
  "name": "grow-more-consultants-backend",
  "version": "1.0.0",
  "description": "Node.js API backend for the Grow More Consultants website.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "build": "npm install --prefix ../frontend && npm run build --prefix ../frontend",
    "start": "node src/server.js",
    "lint": "eslint src",
    "format": "prettier --write ."
  },
  "keywords": [
    "grow-more-consultants",
    "node",
    "express",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "nodemailer": "^9.0.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.4"
  }
}
